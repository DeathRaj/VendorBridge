<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_vendor_bridge_approval_tree" model="ir.ui.view">
        <name>vendor.bridge.approval.tree</name>
        <model>vendor.bridge.approval</model>
        <arch type="xml">
            <tree string="Approvals" decoration-info="status == 'pending'" decoration-success="status == 'approved'" decoration-danger="status == 'rejected'">
                <field name="quotation_id"/>
                <field name="approver_id"/>
                <field name="date"/>
                <field name="remarks"/>
                <field name="status"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_vendor_bridge_approval_form" model="ir.ui.view">
        <name>vendor.bridge.approval.form</name>
        <model>vendor.bridge.approval</model>
        <arch type="xml">
            <form string="Quotation Approval">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="pending,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="quotation_id" readonly="1"/>
                            <field name="approver_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Audit/Approver Remarks">
                        <field name="remarks" attrs="{'readonly': [('status', '!=', 'pending')]}"/>
                    </group>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_vendor_bridge_approval" model="ir.actions.act_window">
        <name>Approvals</name>
        <res_model>vendor.bridge.approval</res_model>
        <view_mode>tree,form</view_mode>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage quotation approvals here.
            </p>
        </help>
    </record>
</odoo>
