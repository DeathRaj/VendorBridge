<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_vendor_bridge_invoice_tree" model="ir.ui.view">
        <name>vendor.bridge.invoice.tree</name>
        <model>vendor.bridge.invoice</model>
        <arch type="xml">
            <tree string="Invoices" decoration-info="status == 'draft'" decoration-warning="status == 'open'" decoration-success="status == 'paid'" decoration-danger="status == 'cancelled'">
                <field name="invoice_number"/>
                <field name="purchase_order_id"/>
                <field name="invoice_date"/>
                <field name="tax_amount"/>
                <field name="total_amount"/>
                <field name="status"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_vendor_bridge_invoice_form" model="ir.ui.view">
        <name>vendor.bridge.invoice.form</name>
        <model>vendor.bridge.invoice</model>
        <arch type="xml">
            <form string="Invoice">
                <header>
                    <button name="action_post_invoice" string="Post Invoice" type="object" class="oe_highlight" attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_register_payment" string="Register Payment" type="object" class="oe_highlight" attrs="{'invisible': [('status', '!=', 'open')]}"/>
                    <button name="action_cancel" string="Cancel" type="object" attrs="{'invisible': [('status', 'in', ['paid', 'cancelled'])]}"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,open,paid,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="invoice_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="invoice_date" attrs="{'readonly': [('status', '!=', 'draft')]}"/>
                        </group>
                        <group>
                            <field name="tax_amount" readonly="1"/>
                            <field name="total_amount" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Item Lines">
                            <field name="quotation_line_ids" readonly="1">
                                <tree>
                                    <field name="product_name"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Search View -->
    <record id="view_vendor_bridge_invoice_search" model="ir.ui.view">
        <name>vendor.bridge.invoice.search</name>
        <model>vendor.bridge.invoice</model>
        <arch type="xml">
            <search string="Search Invoices">
                <field name="invoice_number"/>
                <field name="purchase_order_id"/>
                <field name="status"/>
                <filter string="Draft" name="status_draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Open" name="status_open" domain="[('status', '=', 'open')]"/>
                <filter string="Paid" name="status_paid" domain="[('status', '=', 'paid')]"/>
                <group expand="0" string="Group By">
                    <filter string="Purchase Order" name="group_by_po" context="{'group_by': 'purchase_order_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_vendor_bridge_invoice" model="ir.actions.act_window">
        <name>Invoices</name>
        <res_model>vendor.bridge.invoice</res_model>
        <view_mode>tree,form</view_mode>
        <search_view_id ref="view_vendor_bridge_invoice_search"/>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage your vendor invoices.
            </p>
        </help>
    </record>
</odoo>
