<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_vendor_bridge_activity_log_tree" model="ir.ui.view">
        <name>vendor.bridge.activity.log.tree</name>
        <model>vendor.bridge.activity.log</model>
        <arch type="xml">
            <tree string="Activity Logs" create="false" edit="false" delete="false">
                <field name="timestamp"/>
                <field name="user_id"/>
                <field name="model_name"/>
                <field name="res_id"/>
                <field name="action"/>
                <field name="remarks"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_vendor_bridge_activity_log_form" model="ir.ui.view">
        <name>vendor.bridge.activity.log.form</name>
        <model>vendor.bridge.activity.log</model>
        <arch type="xml">
            <form string="Activity Log" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="timestamp" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="model_name" readonly="1"/>
                            <field name="res_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="action" readonly="1"/>
                        <field name="remarks" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_vendor_bridge_activity_log" model="ir.actions.act_window">
        <name>Activity Logs</name>
        <res_model>vendor.bridge.activity.log</res_model>
        <view_mode>tree,form</view_mode>
        <help type="html">
            <p class="o_view_nocontent_neutral_face">
                No activity logs recorded yet.
            </p>
        </help>
    </record>
</odoo>
