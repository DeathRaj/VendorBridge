<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_vendor_bridge_vendor_tree" model="ir.ui.view">
        <name>vendor.bridge.vendor.tree</name>
        <model>vendor.bridge.vendor</model>
        <arch type="xml">
            <tree string="Vendors">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="gst_number"/>
                <field name="category"/>
                <field name="status"/>
                <field name="rating" widget="priority"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_vendor_bridge_vendor_form" model="ir.ui.view">
        <name>vendor.bridge.vendor.form</name>
        <model>vendor.bridge.vendor</model>
        <arch type="xml">
            <form string="Vendor">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Vendor Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="gst_number"/>
                        </group>
                        <group>
                            <field name="category"/>
                            <field name="status"/>
                            <field name="rating" widget="priority"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Search View -->
    <record id="view_vendor_bridge_vendor_search" model="ir.ui.view">
        <name>vendor.bridge.vendor.search</name>
        <model>vendor.bridge.vendor</model>
        <arch type="xml">
            <search string="Search Vendors">
                <field name="name" filter_domain="['|', '|', ('name', 'ilike', self), ('email', 'ilike', self), ('gst_number', 'ilike', self)]"/>
                <field name="category"/>
                <field name="status"/>
                <filter string="Active" name="status_active" domain="[('status', '=', 'active')]"/>
                <filter string="Services" name="category_services" domain="[('category', '=', 'services')]"/>
                <filter string="Goods" name="category_goods" domain="[('category', '=', 'goods')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category'}"/>
                </group>
            </search>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_vendor_bridge_vendor" model="ir.actions.act_window">
        <name>Vendors</name>
        <res_model>vendor.bridge.vendor</res_model>
        <view_mode>tree,form</view_mode>
        <search_view_id ref="view_vendor_bridge_vendor_search"/>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first vendor!
            </p>
        </help>
    </record>
</odoo>
