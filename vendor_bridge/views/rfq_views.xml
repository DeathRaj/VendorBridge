<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_vendor_bridge_rfq_tree" model="ir.ui.view">
        <name>vendor.bridge.rfq.tree</name>
        <model>vendor.bridge.rfq</model>
        <arch type="xml">
            <tree string="Requests For Quotation" decoration-info="status == 'draft'" decoration-warning="status == 'sent'" decoration-success="status == 'received'">
                <field name="name"/>
                <field name="title"/>
                <field name="deadline"/>
                <field name="quantity"/>
                <field name="status"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_vendor_bridge_rfq_form" model="ir.ui.view">
        <name>vendor.bridge.rfq.form</name>
        <model>vendor.bridge.rfq</model>
        <arch type="xml">
            <form string="Request For Quotation">
                <header>
                    <button name="action_send_rfq" string="Send RFQ" type="object" class="oe_highlight" attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_cancel" string="Cancel" type="object" attrs="{'invisible': [('status', 'in', ['closed', 'cancelled'])]}"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,sent,received,closed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="title" attrs="{'readonly': [('status', 'not in', ['draft'])]}"/>
                            <field name="deadline" attrs="{'readonly': [('status', 'not in', ['draft'])]}"/>
                            <field name="quantity" attrs="{'readonly': [('status', 'not in', ['draft'])]}"/>
                        </group>
                        <group>
                            <field name="assigned_vendor_ids" widget="many2many_tags" attrs="{'readonly': [('status', 'not in', ['draft'])]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product/Service Lines">
                            <field name="line_ids" attrs="{'readonly': [('status', 'not in', ['draft'])]}">
                                <tree editable="bottom">
                                    <field name="product_name"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                </tree>
                            </field>
                        </page>
                        <page string="General Details">
                            <field name="product_details" placeholder="Add any generic descriptions/terms here..." attrs="{'readonly': [('status', 'not in', ['draft'])]}"/>
                        </page>
                        <page string="Quotations Received" attrs="{'invisible': [('status', '=', 'draft')]}">
                            <field name="quotation_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="vendor_id"/>
                                    <field name="total_amount"/>
                                    <field name="delivery_days"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Search View -->
    <record id="view_vendor_bridge_rfq_search" model="ir.ui.view">
        <name>vendor.bridge.rfq.search</name>
        <model>vendor.bridge.rfq</model>
        <arch type="xml">
            <search string="Search RFQs">
                <field name="name"/>
                <field name="title"/>
                <field name="status"/>
                <filter string="Draft" name="status_draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Sent" name="status_sent" domain="[('status', '=', 'sent')]"/>
                <filter string="Quotations Received" name="status_received" domain="[('status', '=', 'received')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    <filter string="Deadline Date" name="group_by_deadline" context="{'group_by': 'deadline'}"/>
                </group>
            </search>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_vendor_bridge_rfq" model="ir.actions.act_window">
        <name>Requests For Quotation</name>
        <res_model>vendor.bridge.rfq</res_model>
        <view_mode>tree,form</view_mode>
        <search_view_id ref="view_vendor_bridge_rfq_search"/>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Request For Quotation (RFQ) to send to vendors.
            </p>
        </help>
    </record>
</odoo>
