<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_vendor_bridge_purchase_order_tree" model="ir.ui.view">
        <name>vendor.bridge.purchase.order.tree</name>
        <model>vendor.bridge.purchase.order</model>
        <arch type="xml">
            <tree string="Purchase Orders" decoration-info="status == 'draft'" decoration-success="status == 'confirmed'" decoration-muted="status == 'done'" decoration-danger="status == 'cancelled'">
                <field name="po_number"/>
                <field name="quotation_id"/>
                <field name="vendor_id"/>
                <field name="total_amount"/>
                <field name="order_date"/>
                <field name="status"/>
            </tree>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_vendor_bridge_purchase_order_form" model="ir.ui.view">
        <name>vendor.bridge.purchase.order.form</name>
        <model>vendor.bridge.purchase.order</model>
        <arch type="xml">
            <form string="Purchase Order">
                <header>
                    <button name="action_confirm_order" string="Confirm Order" type="object" class="oe_highlight" attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_generate_invoice" string="Generate Invoice" type="object" class="oe_highlight" attrs="{'invisible': [('status', '!=', 'confirmed')]}"/>
                    <button name="action_cancel" string="Cancel" type="object" attrs="{'invisible': [('status', 'in', ['done', 'cancelled'])]}"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="po_number" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="quotation_id" readonly="1"/>
                            <field name="vendor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_amount" readonly="1"/>
                            <field name="order_date" attrs="{'readonly': [('status', '!=', 'draft')]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Item Lines">
                            <field name="quotation_line_ids" readonly="1">
                                <tree>
                                    <field name="product_name"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </arch>
    </record>

    <!-- Search View -->
    <record id="view_vendor_bridge_purchase_order_search" model="ir.ui.view">
        <name>vendor.bridge.purchase.order.search</name>
        <model>vendor.bridge.purchase.order</model>
        <arch type="xml">
            <search string="Search Purchase Orders">
                <field name="po_number"/>
                <field name="vendor_id"/>
                <field name="status"/>
                <filter string="Draft" name="status_draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Confirmed" name="status_confirmed" domain="[('status', '=', 'confirmed')]"/>
                <filter string="Done" name="status_done" domain="[('status', '=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Vendor" name="group_by_vendor" context="{'group_by': 'vendor_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </arch>
    </record>

    <!-- Action -->
    <record id="action_vendor_bridge_purchase_order" model="ir.actions.act_window">
        <name>Purchase Orders</name>
        <res_model>vendor.bridge.purchase.order</res_model>
        <view_mode>tree,form</view_mode>
        <search_view_id ref="view_vendor_bridge_purchase_order_search"/>
        <help type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage your Purchase Orders here.
            </p>
        </help>
    </record>
</odoo>
