<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for RFQ -->
        <record id="seq_vendor_bridge_rfq" model="ir.sequence">
            <name>Vendor Bridge RFQ Sequence</name>
            <code>vendor.bridge.rfq</code>
            <prefix>RFQ/</prefix>
            <padding>5</padding>
            <number_next>1</number_next>
            <number_increment>1</number_increment>
            <company_id eval="False"/>
        </record>

        <!-- Sequence for Quotation -->
        <record id="seq_vendor_bridge_quotation" model="ir.sequence">
            <name>Vendor Bridge Quotation Sequence</name>
            <code>vendor.bridge.quotation</code>
            <prefix>QTN/</prefix>
            <padding>5</padding>
            <number_next>1</number_next>
            <number_increment>1</number_increment>
            <company_id eval="False"/>
        </record>

        <!-- Sequence for Purchase Order -->
        <record id="seq_vendor_bridge_purchase_order" model="ir.sequence">
            <name>Vendor Bridge PO Sequence</name>
            <code>vendor.bridge.purchase.order</code>
            <prefix>VB-PO/</prefix>
            <padding>5</padding>
            <number_next>1</number_next>
            <number_increment>1</number_increment>
            <company_id eval="False"/>
        </record>

        <!-- Sequence for Invoice -->
        <record id="seq_vendor_bridge_invoice" model="ir.sequence">
            <name>Vendor Bridge Invoice Sequence</name>
            <code>vendor.bridge.invoice</code>
            <prefix>VB-INV/</prefix>
            <padding>5</padding>
            <number_next>1</number_next>
            <number_increment>1</number_increment>
            <company_id eval="False"/>
        </record>
    </data>
</odoo>
